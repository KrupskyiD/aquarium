generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model aquarium {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(255)
  user_id       Int
  min_salt      Decimal?      @db.Decimal
  max_salt      Decimal?      @db.Decimal
  min_temp      Decimal?      @db.Decimal
  max_temp      Decimal?      @db.Decimal
  device_serial String?       @unique @db.VarChar(100)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  calibration   calibration[]
  metrics       metrics[]
}

model biotopes {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  min_salt    Decimal? @db.Decimal
  max_salt    Decimal? @db.Decimal
  min_temp    Decimal? @db.Decimal
  max_temp    Decimal? @db.Decimal
  description String?
}

model calibration {
  id                  Int       @id @default(autoincrement())
  salinity_value      Decimal   @db.Decimal
  aquarium_id         Int
  duration_ms         Int?
  calibrated_at       DateTime? @default(now()) @db.Timestamptz(6)
  next_calibration_at DateTime? @db.Timestamptz(6)
  aquarium            aquarium  @relation(fields: [aquarium_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model metrics {
  id          Int       @id @default(autoincrement())
  aquarium_id Int
  temperature Decimal   @db.Decimal
  salinity    Decimal   @db.Decimal
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  aquarium    aquarium  @relation(fields: [aquarium_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(255)
  email              String               @unique @db.VarChar(255)
  password_hash      String               @db.VarChar(255)
  is_verified        Boolean?             @default(false)
  refresh_token      String?              @db.VarChar(255)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  aquarium           aquarium[]
  verification_token verification_token[]
}

model verification_token {
  id         Int      @id @default(autoincrement())
  token      String   @unique @db.VarChar(255)
  user_id    Int
  expires_at DateTime @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
